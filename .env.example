# SplitStreak local development environment.
# Replace these examples with real values in an untracked .env or deployment environment.

# HTTP server
HOST=0.0.0.0
PORT=8080
SELF_URL=http://localhost:5173
STATIC_DIR=frontend/dist

# PostgreSQL
DATABASE_URL=postgres://splitstreak:splitstreak@localhost:5432/splitstreak?sslmode=disable
DATABASE_MAX_CONNECTIONS=5

# Ideavibes auth service
MCTAI_AUTH_URL=https://auth.mctai.app
MCTAI_AUTH_APP_TOKEN=app_local_splitstreak
MCTAI_AUTH_JWKS_URL=https://auth.mctai.app/.well-known/jwks.json

# Legacy compatibility only. New auth code should verify the mctai_session cookie.
JWT_SECRET=replace-with-a-long-random-development-secret

# Ideavibes email service
MCTAI_EMAIL_URL=https://email.mctai.app/send
MCTAI_EMAIL_APP_TOKEN=email_local_splitstreak
