{
  "name": "splitstreak",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"cargo run --manifest-path backend/Cargo.toml\" \"npm run dev --workspace frontend\"",
    "build": "npm run build --workspace frontend && cargo build --manifest-path backend/Cargo.toml",
    "typecheck": "npm run typecheck --workspace frontend",
    "lint": "npm run lint --workspace frontend && cargo clippy --manifest-path backend/Cargo.toml --all-targets -- -D warnings",
    "format": "prettier --write \"**/*.{css,html,json,md,ts,tsx}\" && cargo fmt --manifest-path backend/Cargo.toml",
    "format:check": "prettier --check \"**/*.{css,html,json,md,ts,tsx}\" && cargo fmt --manifest-path backend/Cargo.toml -- --check",
    "backend:dev": "cargo run --manifest-path backend/Cargo.toml",
    "backend:lint": "cargo clippy --manifest-path backend/Cargo.toml --all-targets -- -D warnings",
    "backend:format": "cargo fmt --manifest-path backend/Cargo.toml",
    "backend:format:check": "cargo fmt --manifest-path backend/Cargo.toml -- --check",
    "frontend:dev": "npm run dev --workspace frontend",
    "frontend:lint": "npm run lint --workspace frontend",
    "frontend:format": "npm run format --workspace frontend",
    "frontend:format:check": "npm run format:check --workspace frontend"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.18.2"
  }
}
